<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.adoramon.hermes-apple-calendar-outbox-consumer</string>

  <key>WorkingDirectory</key>
  <string>/Users/administrator/Code/hermes-apple-calendar-assistant</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/python3</string>
    <string>scripts/outbox_consumer.py</string>
    <string>dry-run</string>
    <string>--limit</string>
    <string>10</string>
  </array>

  <key>StartInterval</key>
  <integer>60</integer>

  <key>StandardOutPath</key>
  <string>/Users/administrator/Code/hermes-apple-calendar-assistant/logs/outbox_consumer.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/administrator/Code/hermes-apple-calendar-assistant/logs/outbox_consumer.err.log</string>

  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
